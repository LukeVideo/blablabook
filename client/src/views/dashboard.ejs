<%- include('./partials/head') %>
<%- include('./partials/header') %>

<section class="profile-container">
    <% if (locals.reader) { %>
        <h2>Dashboard de <%= locals.reader.nickname %></h2>
    
    <!-- Affichage des informations du profil de l'utilisateur -->
        <div class="profile-info">
            <p>Pseudo : <%= locals.reader.nickname %></p>
            <p>Nom : <%= locals.reader.lastname %></p>
            <p>Prénom : <%= locals.reader.firstname %></p>
            <p>Email : <%= locals.reader.email %></p>
        </div>
    <% } %>

<!-- Si l'utilisateur est un admin, on peut lui offrir des actions supplémentaires -->
    <% if (locals.isAdmin) { %>
        <h3>Actions administratives :</h3>
        <form action="">
            <button>Gérer les utilisateurs </button>
        </form>

        <form action="/api/search" method="GET">
            <button type="submit">Ajouter un livre à la base de données</button>
        </form>

        <form action="">
            <button>Supprimer un livre de la base de données</button>
        </form>
    <% } %>

<!-- Affichage des messages, s'il y en a -->
    <% if (locals.message) { %>
        <p><%= locals.message %></p>
    <% } %>
</section>

<%- include('./partials/footer') %>