<%- include('./partials/head') %>
<%- include('./partials/header') %>

<section class="container mx-auto px-4 py-8">
   <div class="flex items-center gap-6 bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold text-peacock">Dashboard de <%= locals.reader.nickname %></h2>
      <img class="w-20 h-20 rounded-full object-cover shadow-md" src="/images/avatar.jpg" alt="avatar"> 
   </div> 

   <div class="grid md:grid-cols-2 gap-8">
      <% if (locals.reader) { %>
      <div class="bg-white rounded-lg shadow-md p-6 space-y-4">
          <p class="text-gray-700"><span class="font-semibold">Pseudo :</span> <%= locals.reader.nickname %></p>
          <p class="text-gray-700"><span class="font-semibold">Nom :</span> <%= locals.reader.lastname %></p>
          <p class="text-gray-700"><span class="font-semibold">Prénom :</span> <%= locals.reader.firstname %></p>
          <p class="text-gray-700"><span class="font-semibold">Email :</span> <%= locals.reader.email %></p>
          <p><a href="/bookshelf" class="inline-flex items-center text-peacock hover:text-peacock/80 transition-colors">
            📚 <span class="ml-2">Ma Bibliothèque</span>
          </a></p>
      </div>
      <% } %>

      <% if (locals.isAdmin) { %>
      <div class="bg-white rounded-lg shadow-md p-6 space-y-4">
          <h3 class="text-xl font-semibold text-peacock mb-4">⚙️ Actions administratives :</h3>
          <form class="space-y-3">
            <button class="w-full bg-peacock text-white py-2 px-4 rounded-lg hover:bg-peacock/90 transition-colors text-left">
              👤 Gérer les utilisateurs
            </button>
          </form>
          <form action="/api/search" method="GET">
              <button class="w-full bg-peacock text-white py-2 px-4 rounded-lg hover:bg-peacock/90 transition-colors text-left" type="submit">
                ➕ Ajouter un livre
              </button>
          </form>
          <form>
            <button class="w-full bg-red-600 text-white py-2 px-4 rounded-lg hover:bg-red-700 transition-colors text-left">
              ❌ Supprimer un livre
            </button>
          </form>
      </div>
      <% } %>
   </div>
</section>

<%- include('./partials/footer') %>


