<article class="w-full bg-white rounded-lg shadow-md overflow-hidden border border-gray-200 h-[32rem]">
    <div class="p-4 bg-peacock text-white h-24">
        <p class="text-xl font-semibold line-clamp-2">
            <%= book.title %> 
            <span class="text-sm text-gray-200 ml-2"> 
                (<%= book.author.firstname %> <%= book.author.lastname %>)
            </span>
        </p>
    </div>
    
    <div class="flex p-4 gap-4 h-[calc(32rem-10rem)]">
        <div class="w-1/3 h-full">
            <img 
                class="w-full h-full object-cover rounded-md shadow-sm" 
                src="<%= book.book_cover || '/images/BlaBlaBook_logo.png' %>" 
                alt="Couverture du livre <%= book.title %>"
                onerror="this.onerror=null; this.src='/images/DefaultBookCoverImg.png';">
        </div>
        <div class="w-2/3 flex flex-col h-full">   
            
            <% if (locals.book_status) { %>
                <form action="/status/<%= book.id %>/<%= locals.book_status.id %>/" method="post" class="mb-4">
                    <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status:</label>
                    <input type="hidden" id="BookInBookshelf_id" name="BookInBookshelf_id" value="<%= BookInBookshelf_id %>">
                    <select id="status" name="status" onchange="this.form.submit()" class="w-full rounded-md border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock">
                        <% locals.statuses.forEach((status) => { %>
                            <option value="<%- status.id %>"
                                <% if (status.book_status === locals.book_status.book_status) { %>
                                    selected 
                                <% } %>
                            ><%- status.book_status %></option>
                        <% }); %> 
                    </select>
                </form>   
            <% } %>

            <div class="flex-grow">
                <p class="font-medium text-gray-700 mb-2">Résumé :</p>
                <p class="text-gray-600 text-sm line-clamp-4"><%= book.book_description %></p>
            </div>

        </div>
    </div>
    <div class="flex justify-between items-center px-4 py-3 bg-gray-50 border-t border-gray-200 h-16">
        <div>
            <form action="/book/<%= book.id %>" method="GET">
                <button class="px-4 py-2 bg-peacock text-white rounded-md hover:bg-peacock/90 transition-colors">Détails</button>
            </form>
        </div>
        <div>
            <% if (!locals.displayRemoveButton) { %>
                <form action="/addBookToBookshelf" method="POST">
                    <input type="hidden" name="book_id" value="<%= book.id %>">
                    <button class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition-colors" type="submit" aria-label="Ajouter <%= book.title %> à ma Bookshelf">
                        Ajouter à ma Bookshelf
                    </button>
                </form>
            <% } %>
    
            <% if (locals.displayRemoveButton) { %>
                <form action="/deleteBookFromBookshelf" method="POST">
                    <input type="hidden" name="book_id" value="<%= book.id %>">
                    <button class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors" type="submit" alt="Retirer <%= book.title %> de ma Bookshelf">
                        Retirer de ma Bookshelf
                    </button>
                </form>
            <% } %>
        </div>
    </div>
</article>
