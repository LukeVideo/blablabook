<!-- Menu Desktop -->
<nav class="hidden md:flex items-center gap-4">
  <div class="bookmark"><a href="/index">Accueil</a></div>

  <% if (!locals.reader) { %>
    <div class="bookmark-disabled">Search</div>
    <div class="bookmark-disabled">Dashboard</div>
    <div class="bookmark-disabled">Bookshelf</div>
    <div class="bookmark"><a href="/login">Login / Register</a></div>
  <% } else { %>
    <div class="bookmark"><a href="/search">Search</a></div>
    <div class="bookmark"><a href="/dashboard">Dashboard</a></div>
    <div class="bookmark"><a href="/bookshelf">Bookshelf</a></div>
    <div class="bookmark">
      <form action="/logout" method="POST">
        <button type="submit" name="logout" id="logout">Déconnexion</button>
      </form>
    </div>
  <% } %>
</nav>

<!-- Bandeau Mobile -->
<nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-lg z-50 pb-safe">
  <div class="flex justify-around items-center px-1 py-2">
    <a href="/index" class="flex flex-col items-center min-w-[4rem] text-peacock hover:bg-beige rounded-lg px-1">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      <span class="text-[10px] mt-0.5">Accueil</span>
    </a>

    <% if (!locals.reader) { %>
      <a href="/login" class="flex flex-col items-center min-w-[4rem] text-peacock hover:bg-beige rounded-lg px-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
        </svg>
        <span class="text-[10px] mt-0.5">Connexion</span>
      </a>
    <% } else { %>
      <a href="/search" class="flex flex-col items-center min-w-[4rem] text-peacock hover:bg-beige rounded-lg px-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Recherche</span>
      </a>

      <a href="/dashboard" class="flex flex-col items-center min-w-[4rem] text-peacock hover:bg-beige rounded-lg px-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Dashboard</span>
      </a>

      <a href="/bookshelf" class="flex flex-col items-center min-w-[4rem] text-peacock hover:bg-beige rounded-lg px-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        <span class="text-[10px] mt-0.5">Bookshelf</span>
      </a>

      <form action="/logout" method="POST" class="flex items-center">
        <button type="submit" class="flex flex-col items-center min-w-[4rem] text-red-600 hover:bg-red-50 rounded-lg px-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          <span class="text-[10px] mt-0.5">Déconnexion</span>
        </button>
      </form>
    <% } %>
  </div>
</nav>
