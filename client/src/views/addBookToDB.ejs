<%- include('./partials/head') %>
<body> 
  <%- include('./partials/header') %>
  
  <% if (locals.reader) { %>
    <div class="container mx-auto px-4 py-8">
      <h2 class="text-2xl font-bold text-peacock mb-6 text-center">Recherche d'un livre sur l'API Google Books</h2>
      <section class="max-w-2xl mx-auto">
        <form action="/api/getBookList" method="POST" class="bg-white rounded-lg shadow-md p-6 mb-8 space-y-4">
          <div class="space-y-2">
            <label for="titleFromAPI" class="block text-gray-700 font-medium">Titre :</label>
            <input type="text" 
                   id="titleFromAPI" 
                   name="titleFromAPI" 
                   placeholder="Titre"
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock">
          </div>
          
          <div class="space-y-2">
            <label for="authorFromAPI" class="block text-gray-700 font-medium">Auteur :</label>
            <input type="text" 
                   id="authorFromAPI" 
                   name="authorFromAPI" 
                   placeholder="Auteur"
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock">
          </div>
          
          <div class="space-y-2">
            <label for="isbnFromAPI" class="block text-gray-700 font-medium">ISBN :</label>
            <input type="text" 
                   id="isbnFromAPI" 
                   name="isbnFromAPI" 
                   placeholder="ISBN"
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock">
          </div>
          
          <button type="submit" 
                  class="w-full bg-peacock text-white py-2 px-4 rounded-lg hover:bg-peacock/90 transition-colors">
            Rechercher
          </button>
        </form>

        <% if (locals.bookList) { %>
          <ul class="space-y-6">
            <% locals.bookList.forEach((book) => { %>
              <li class="bg-white rounded-lg shadow-md p-6">
                <div class="flex flex-col md:flex-row gap-6">
                  <div class="md:w-1/3">
                    <% if (book.imageLink) { %>
                      <img src="<%= book.imageLink %>" 
                           alt="Couverture du livre"
                           class="w-full rounded-lg shadow-sm">
                    <% } else { %>
                      <div class="bg-gray-200 rounded-lg p-4 text-center text-gray-500">
                        Image non disponible
                      </div>
                    <% } %>
                  </div>

                  <div class="md:w-2/3 space-y-4">
                    <h3 class="text-xl font-bold text-peacock">
                      <%= book.title ? book.title : 'Non renseigné' %>
                    </h3>
                    <p class="text-gray-700">
                      <span class="font-medium">Auteur:</span> 
                      <%= book.authors ? book.authors.join(', ') : 'Inconnu' %>
                    </p>
                    <p class="text-gray-700">
                      <span class="font-medium">ISBN-10:</span> 
                      <%= book.isbn10 ? book.isbn10 : 'Non renseigné' %>
                    </p>
                    <p class="text-gray-700">
                      <span class="font-medium">ISBN-13:</span> 
                      <%= book.isbn13 ? book.isbn13 : 'Non renseigné' %>
                    </p>
                    <p class="text-gray-600 text-sm line-clamp-3">
                      <span class="font-medium">Description:</span> 
                      <%= book.description ? book.description : 'Non renseigné' %>
                    </p>

                    <form action="/api/addBookToDB" method="POST" class="mt-4">
                      <input type="hidden" name="title" value="<%= book.title %>">
                      <button type="submit" 
                              class="bg-green-600 text-white py-2 px-4 rounded-lg hover:bg-green-700 transition-colors">
                        Ajouter à la base de données
                      </button>
                    </form>
                  </div>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </section>
    </div>
  <% } %>  

  <% if (locals.message) { %>
    <p class="text-center text-peacock bg-beige p-4 rounded-lg mx-4 mb-8">
      <%= locals.message %>
    </p>
  <% } %>
  
  <%- include('./partials/footer') %>


