<!DOCTYPE html>
<html lang="fr">

<head>
  <!-- Common styles, scripts, and meta tags -->
  <%- include('./partials/head') %>

<!-- rajouter les CSS et le favicon -->

  <!-- Title -->
  <title>Ajouter un livre</title>

</head>

<body> 
  <%- include('./partials/header') %>
  <%- include('./partials/menu') %>
  
  
  <% if (locals.reader) { %>
    <h2>Bonjour <%= locals.reader.nickname %></h2>
    <section>
        <form action="/API/BookList" method="POST" type="submit" name="searchFromAPI">
