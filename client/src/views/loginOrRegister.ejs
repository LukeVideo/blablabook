<%- include('./partials/head') %>

<body>
  <%- include('./partials/header') %>

  <section class="container mx-auto px-4 py-8 max-w-md">
    <div class="bg-white rounded-lg shadow-md p-6">
      <% if (locals.reader) { %>
        <!-- Section utilisateur connecté -->
        <div class="text-center">
          <h2 class="text-2xl font-bold text-peacock mb-4">Bonjour <%= locals.reader.nickname %> !</h2>
          <p class="text-gray-600 mb-6">Vous êtes connecté à votre compte BlaBlaBook.</p>
          <form class="space-y-4" action="/logout" method="POST">
            <button class="w-full bg-red-600 text-white py-3 px-4 rounded-lg hover:bg-red-700 transition-colors" 
                    type="submit" name="logout">
              Se déconnecter
            </button>
          </form>
        </div>
      <% } else { %>
        <!-- Onglets de navigation -->
        <div class="flex mb-6 border-b">
          <button id="login-btn" 
                  onclick="showTab('login')"
                  class="flex-1 py-3 text-center font-medium transition-colors hover:text-peacock border-b-2 border-peacock">
            Connexion
          </button>
          <button id="register-btn" 
                  onclick="showTab('register')"
                  class="flex-1 py-3 text-center font-medium transition-colors hover:text-peacock border-b-2 border-transparent">
            Inscription
          </button>
        </div>
        
        <form id="login-form" class="space-y-4" action="/login" method="POST">
          <div class="space-y-2">
            <label for="email" class="block text-gray-700 font-medium">Adresse mail:</label>
            <input type="email" id="email" name="email" 
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                   placeholder="Votre adresse mail" required>
          </div>
          <div class="space-y-2">
            <label for="password" class="block text-gray-700 font-medium">Mot de passe:</label>
            <input type="password" id="password" name="password" 
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                   placeholder="Votre mot de passe" required>
          </div>
          <button class="w-full bg-peacock text-white py-2 px-4 rounded-lg hover:bg-peacock/90 transition-colors" 
                  type="submit">
            Connexion
          </button>
        </form>

        <form id="register-form" class="space-y-4 hidden" action="/register" method="POST">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label for="firstname" class="block text-gray-700 font-medium">Prénom</label>
              <input type="text" id="firstname" name="firstname" 
                     class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                     placeholder="Prénom" required>
            </div>
            <div class="space-y-2">
              <label for="lastname" class="block text-gray-700 font-medium">Nom</label>
              <input type="text" id="lastname" name="lastname" 
                     class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                     placeholder="Nom de famille" required>
            </div>
          </div>
          
          <div class="space-y-2">
            <label for="nickname" class="block text-gray-700 font-medium">Pseudonyme</label>
            <input type="text" id="nickname" name="nickname" 
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                   placeholder="Pseudonyme" required>
          </div>

          <div class="space-y-2">
            <label for="register-email" class="block text-gray-700 font-medium">Email</label>
            <input type="email" id="register-email" name="email" 
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                   placeholder="Adresse mail" required>
          </div>

          <div class="space-y-2">
            <label for="register-password" class="block text-gray-700 font-medium">Mot de passe</label>
            <input type="password" id="register-password" name="password" 
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                   placeholder="Mot de passe" required>
          </div>

          <div class="space-y-2">
            <label for="confirm_password" class="block text-gray-700 font-medium">Confirmer</label>
            <input type="password" id="confirm_password" name="confirm_password" 
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock"
                   placeholder="Confirmer le mot de passe" required>
          </div>

          <button class="w-full bg-peacock text-white py-2 px-4 rounded-lg hover:bg-peacock/90 transition-colors" 
                  type="submit">
            S'inscrire
          </button>
        </form>

      <!-- Messages de succès ou d'erreur -->
      <% if (locals.message) { %>
        <div class="mt-4 p-4 rounded-lg text-center <%= locals.error ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %>">
          <%= locals.message %>
        </div>
      <% } %>

      <% if (locals.error) { %>
        <div class="mt-4 p-4 bg-red-100 text-red-700 rounded-lg text-center">
          <%= locals.error %>
        </div>
      <% } %>
      <% } %>
    </div>
  </section>

  <%- include('./partials/footer') %>

  <script>
    function showTab(tabName) {
      // Mettre à jour les classes des boutons
      document.getElementById('login-btn').classList.toggle('border-peacock', tabName === 'login');
      document.getElementById('register-btn').classList.toggle('border-peacock', tabName === 'register');
      
      // Afficher/masquer les formulaires
      document.getElementById('login-form').classList.toggle('hidden', tabName !== 'login');
      document.getElementById('register-form').classList.toggle('hidden', tabName !== 'register');

      // Mettre à jour le titre de la page si nécessaire
      document.title = tabName === 'login' ? 'Connexion - BlaBlaBook' : 'Inscription - BlaBlaBook';
    }

    // Définir l'onglet initial en fonction de l'URL ou des paramètres
    document.addEventListener('DOMContentLoaded', function() {
      const params = new URLSearchParams(window.location.search);
      const tab = params.get('tab') || 'login';
      showTab(tab);
    });
  </script>
</body>
