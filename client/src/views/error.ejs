<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container mx-auto px-4 py-16 flex flex-col items-center">
  <div class="max-w-lg w-full">
    <!-- Image container with frame -->
    <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
      <img src="/images/BlaBlaBook_logo.png" 
           alt="BlaBlaBook Error" 
           class="mx-auto max-h-48 object-contain">
    </div>

    <!-- Error message container -->
    <div class="bg-white rounded-lg shadow-lg p-6 text-center">
      <% if (typeof status !== 'undefined') { %>
        <h1 class="text-4xl font-bold text-red-600 mb-4">Erreur <%= status %></h1>
      <% } else { %>
        <h1 class="text-4xl font-bold text-red-600 mb-4">Une erreur est survenue</h1>
      <% } %>

      <% if (typeof message !== 'undefined') { %>
        <p class="text-gray-600 mb-6"><%= message %></p>
      <% } %>

      <% if (status === 404) { %>
        <div class="mb-6">
                    <img src="https://media1.tenor.com/images/a45e05cae2a06e6edb9a0d2d6ed632bb/tenor.gif?itemid=12587594" 
                alt="Page introuvable" 
                class="mx-auto max-h-48 object-contain rounded-lg shadow-md">
        </div>
      <% } %>

      <a href="/" class="inline-block bg-peacock text-white px-6 py-2 rounded-lg hover:bg-peacock/90 transition-colors">
        Retour à l'accueil
      </a>
    </div>

    <% if (typeof stackHighlighted !== 'undefined' && process.env.DEV_ENV === 'true') { %>
      <div class="mt-8 bg-gray-100 rounded-lg p-4 overflow-x-auto">
        <div class="stack-trace font-mono text-sm text-gray-700">
          <%- stackHighlighted %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
