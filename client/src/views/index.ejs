<%- include('./partials/head') %>

<%- include('./partials/header') %>


<div class="index-section">


  <% if (locals.message) { %>
    <p><%= locals.message %></p>
<% } %>

<% if (locals.latestBooks && locals.latestBooks.length > 0) { %>
  <h2>Les 5 derniers livres ajoutés :</h2>
  <section class="booklist-section">
    <ul>
      <% locals.latestBooks.forEach((book) => { %>
        <li>
          <%- include('partials/bookThumbnail', {book: book}) %> 
        </li>
      <% }); %> 
    </ul>
  </section>
<% } %>

<!-- add last comments -->

<h2>Derniers avis des lecteurs</h2>
<div class="lastReviews">
<% if (locals.lastReviews && locals.lastReviews.length > 0) { %>

  <ul>
        <% locals.lastReviews.forEach(review => { %>
            <li>
                <p><%= review.book_review.title %></p>
                <p>Note : <%= review.note %>/5</p>
                <p>"<%= review.review %>"</p>
                
                
                <small>Posté le <%= new Date(review.created_at).toLocaleDateString('fr-FR') %></small> par <%= review.reader.nickname %> 
            </li>
        <% }) %>
    </ul>
<% } else { %>
    <p>Aucun avis pour le moment.</p>
<% } %>
</div>
<!-- end of add last comments -->



<% if (locals.randomAuthors && locals.randomAuthors.length > 0) { %>
  <section class="random-authors-section">
    <h2>Auteurs aléatoires :</h2>
    <ul>
      <% locals.randomAuthors.forEach((author) => { %>
        <li>
          <a class="random_authors_link" href="/author/<%= author.id %>"><%= author.firstname %> <%= author.lastname %></a>
        </li>
      <% }); %>
    </ul>
  </section>
<% } %>

<% if (locals.bookList) { %>
  <section class="booklist-section">
    
    <ul>
      
      <% locals.bookList.forEach((book) => { %>
        <!-- Gestion des erreurs en cas de champ vide avec une ternaire -->
        
        <li><%- include('partials/bookThumbnail', {book: book}) %></li>
        
      <% }); %> 
    </ul>
      
    <% } %>
    
    
  </section>
</div>
<%- include('./partials/footer') %>
