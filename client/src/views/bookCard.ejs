<%- include('./partials/head') %>

<%- include('./partials/header') %>
<div class="index-section">
<% if (locals.reader) { %>
    <%- include('./partials/nickname', {nickname: locals.reader.nickname}) %>
<% } %>


<article class="book-detail second-background">
    <img class="book-card-image" src="/images/photo.png" alt="">

    <header class="book-card-header">
        <h2><%= book.title %></h2>
        <h3>Auteur(s): <a href="/author/<%= book.author.id %>"><%= book.author.firstname %> <%= book.author.lastname %></a></h3>


        <% if (!locals.displayRemoveButton) { %>
    
            <form action="/addBookToBookshelf" method="POST">
                <input type="hidden" name="book_id" value="<%= book.id %>">
                <button  type="submit" alt="Ajouter <%= book.title %> à ma Bookshelf">
                    Ajouter à ma Bookshelf</button>
            </form>
                
        <% }else{ %>

            <form action="/deleteBookFromBookshelf" method="POST">
                <input type="hidden" name="book_id" value="<%= book.id %>">
                <button  type="submit" alt="Retirer <%= book.title %> de ma Bookshelf">
                    Retirer de ma Bookshelf</button>
            </form>
                
        <% } %>

    </header>
    <p class="book-card-description"><%= book.book_description %></p>
    
</article>
</div>

<%- include('./partials/footer') %>

