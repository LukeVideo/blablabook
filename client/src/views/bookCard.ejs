<%- include('./partials/head') %>
<%- include('./partials/header') %>
<% if (locals.reader) { %>
    <%- include('./partials/nickname', {nickname: locals.reader.nickname}) %>
<% } %>

<div class="book_details">
    <div class="book_group">
        <div class="book_cover">
            <img src="<%= book.book_cover || './images/DefaultBookCoverImg.png' %>" alt="Couverture du livre <%= book.title %>">
        </div>
        <div class="book_settings">
            <button>Statut</button>
            <div class="book_thumbnail_button">
                <% if (!locals.displayRemoveButton) { %>
                    <form action="/addBookToBookshelf" method="POST">
                        <input type="hidden" name="book_id" value="<%= book.id %>">
                        <button  class="book_thumbnail_button"type="submit" alt="Ajouter <%= book.title %> à ma Bookshelf">
                            Ajouter à ma Bookshelf
                        </button>
                    </form>
                <% } %>
        
                <% if (locals.displayRemoveButton) { %>
                    <form action="/deleteBookFromBookshelf" method="POST">
                        <input type="hidden" name="book_id" value="<%= book.id %>">
                        <button class="book_thumbnail_button" type="submit" alt="Retirer <%= book.title %> de ma Bookshelf">
                            Retirer de ma Bookshelf
                        </button>
                    </form>
                <% } %>
            </div>
        </div>
    </div>
    <div class="book_infos">
        <div class="book_infos_header">
            <div class="book_title"><%= book.title %></div>
            <div class="book_author">
                Auteur(s): <a href="/author/<%= book.author.id %>"><%= book.author.firstname %> <%= book.author.lastname %></a>    
            </div>
        </div>
        <div class="book_infos_review">
            <div class="book_AvgNote">Note Moyenne : </div>
            <div class="book_NbComment">Nombre d'avis: </div>
        </div>
        <div class="book_description">
            <p>Synopsis : 
                <p><%= book.book_description %></p>
            </p>
        </div>
    </div>
</div>
<div class="book_reviews">
    <article class="book_readerReview">
        <div class="Reader_avatar">
            <img src="/images/avatar.jpg" alt="Avatar de l'utilisateur">
        </div>
        <div class="Reader_nickname">Pseudo de l'utilisateur</div>
        <div class="review_date">Date de dépôt de l'avis</div>
        <div class="Reader_reviewNote">Note laissée par l'utilisateur</div>
        <div class="Reader_comment">Commentaire de l'utilisateur</div>
    </article>
</div>

<%- include('./partials/footer') %>
