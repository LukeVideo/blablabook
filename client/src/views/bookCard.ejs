<%- include('./partials/head') %>
<%- include('./partials/header') %>
<% if (locals.reader) { %>
    <%- include('./partials/nickname', {nickname: locals.reader.nickname}) %>
<% } %>

<div class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-8 bg-white rounded-lg shadow-lg p-6 mb-8">
        <div class="md:w-1/3">
            <div class="max-h-[400px] aspect-[2/3] overflow-hidden rounded-lg shadow-md mx-auto">
                <img src="<%= book.book_cover || '/images/DefaultBookCoverImg.png' %>" 
                     alt="Couverture du livre <%= book.title %>"
                     class="w-full h-full object-cover">
            </div>
            <div class="mt-4 space-y-4">
                <button class="w-full bg-peacock text-white py-2 px-4 rounded-lg hover:bg-peacock/90 transition-colors">Statut</button>
                <div class="space-y-2">
                    <% if (!locals.displayRemoveButton) { %>
                        <form action="/addBookToBookshelf" method="POST">
                            <input type="hidden" name="book_id" value="<%= book.id %>">
                            <button type="submit" 
                                    class="w-full bg-green-600 text-white py-2 px-4 rounded-lg hover:bg-green-700 transition-colors"
                                    alt="Ajouter <%= book.title %> à ma Bookshelf">
                                Ajouter à ma Bookshelf
                            </button>
                        </form>
                    <% } %>
            
                    <% if (locals.displayRemoveButton) { %>
                        <form action="/deleteBookFromBookshelf" method="POST">
                            <input type="hidden" name="book_id" value="<%= book.id %>">
                            <button type="submit" 
                                    class="w-full bg-red-600 text-white py-2 px-4 rounded-lg hover:bg-red-700 transition-colors"
                                    alt="Retirer <%= book.title %> de ma Bookshelf">
                                Retirer de ma Bookshelf
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
        </div>
        <div class="md:w-2/3">
            <div class="space-y-4">
                <h1 class="text-3xl font-bold text-peacock"><%= book.title %></h1>
                <div class="text-lg text-gray-600">
                    Auteur(s): <a href="/author/<%= book.author.id %>" class="text-peacock hover:text-peacock/70 transition-colors">
                        <%= book.author.firstname %> <%= book.author.lastname %>
                    </a>    
                </div>
            </div>
            <div class="mt-6 space-y-2">
                <div class="text-amber-500 font-medium">Note Moyenne : </div>
                <div class="text-gray-600">Nombre d'avis: </div>
            </div>
            <div class="mt-8">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">Synopsis :</h2>
                <p class="text-gray-600 leading-relaxed"><%= book.book_description %></p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
        <article class="flex gap-4 items-start">
            <div class="w-16 h-16 rounded-full overflow-hidden flex-shrink-0">
                <img src="/images/avatar.jpg" alt="Avatar de l'utilisateur" class="w-full h-full object-cover">
            </div>
            <div class="flex-grow space-y-2">
                <div class="font-semibold text-lg text-peacock">Pseudo de l'utilisateur</div>
                <div class="text-sm text-gray-500">Date de dépôt de l'avis</div>
                <div class="text-amber-500">Note laissée par l'utilisateur</div>
                <div class="text-gray-600">Commentaire de l'utilisateur</div>
            </div>
        </article>
    </div>

    <% if (locals.reader) { %>    
        <section class="bg-white rounded-lg shadow-lg p-6 mb-8">
            <form action="/book/<%= book.id %>/review" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label for="note" class="block text-gray-700 font-medium">Note</label>
                    <select name="note" id="note" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock">
                        <option value="0">Noter ce livre</option>
                        <option value="5">★★★★★</option>
                        <option value="4">★★★★</option>
                        <option value="3">★★★</option>
                        <option value="2">★★</option>
                        <option value="1">★</option>
                    </select>
                </div>

                <div class="space-y-2">
                    <label for="review" class="block text-gray-700 font-medium">Commentaire</label>
                    <textarea name="review" 
                              class="w-full rounded-lg border-gray-300 shadow-sm focus:border-peacock focus:ring-peacock h-32"
                              placeholder="Ecrire un commentaire"></textarea>
                </div>

                <button type="submit" 
                        class="bg-peacock text-white px-6 py-2 rounded-lg hover:bg-peacock/90 transition-colors">
                    Envoyer
                </button>
            </form>
        </section>
    <% } %>

    <section class="bg-white rounded-lg shadow-lg p-6">
        <h2 class="text-2xl font-bold text-peacock mb-6">Avis des lecteurs</h2>

        <p class="text-lg mb-6">
            Note moyenne : 
            <% if (bookAvgNote > 0) { %>
                <span class="text-amber-500 font-medium"><%= bookAvgNote %> / 5</span>
            <% } else { %>
                <span class="text-gray-500">Non noté</span>
            <% } %>
        </p>

        <% if (book.book_reviews && book.book_reviews.length > 0) { %>
            <ul class="space-y-6">
                <% book.book_reviews.forEach(review => { %>
                    <li class="border-b border-gray-200 pb-4 last:border-b-0">
                        <p class="font-medium text-peacock"><%= review.reader.firstname %> <%= review.reader.lastname %></p>
                        <p class="text-amber-500 my-2">Note : <%= review.note %>/5 </p>
                        <p class="text-gray-600 italic">"<%= review.review %>"</p>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p class="text-gray-500 text-center">Aucun avis pour ce livre.</p>
        <% } %>
    </section>
</div>

<%- include('./partials/footer') %>
