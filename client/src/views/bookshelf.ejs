<%- include('./partials/head') %>
<%- include('./partials/header') %>
  
<script>
  const localsData = <%- JSON.stringify(locals) %>;
  console.log(localsData);
</script>

<div class="container mx-auto px-4 py-8">
  <% if (!locals.reader) { %>
    <%- include('./partials/loginNeeded') %>
  <% } %>
  
  <% if (locals.reader) { %>
    <h2 class="text-2xl font-bold text-peacock mb-8">Bookshelf de <%= locals.reader.nickname %></h2>
 
    <% if (locals.bookshelf) { %>
      <section class="mb-8">
        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% locals.bookshelf.BookInBookshelves.forEach((bookshelfItem) => { %>
            <li>
              <%- include('partials/bookThumbnail', {
                book: bookshelfItem.Book, 
                book_status: bookshelfItem.BookStatus, 
                BookInBookshelf_id: bookshelfItem.id
              }) %>
            </li>
          <% }); %> 
        </ul>
      </section>
    <% } %>
  <% } %>  
</div>

<% if (locals.message) { %>
  <p class="text-center text-peacock bg-beige p-4 rounded-lg mx-4 mb-8"><%= locals.message %></p>
<% } %>
  
<%- include('./partials/footer') %>


